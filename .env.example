# =============================================================================
# GoMVP — F0 Fundação
# Copie este arquivo para .env.local e preencha com seus valores reais.
# NUNCA comite .env.local. Apenas .env.example entra no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (dev)
# -----------------------------------------------------------------------------
# Connection string do Postgres do Supabase (use o pooler para apps serverless).
# Formato: postgresql://postgres:<password>@<host>:5432/postgres
DATABASE_URL=postgresql://postgres:CHANGE_ME@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# URL pública do projeto Supabase. Exposta ao browser por design.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Chave anon do Supabase. Exposta ao browser por design (RLS protege os dados).
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME

# Chave service role do Supabase. SERVER-ONLY. NUNCA exponha em client.
# Usada apenas em scripts (seed/migrate) e route handlers protegidos.
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# OpenAI (D-02 — modelos via ENV; em F0 nada é chamado em runtime)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ALLOW_PAID_AI=false
AI_MONTHLY_BUDGET_USD=50

# -----------------------------------------------------------------------------
# Vercel Cron
# -----------------------------------------------------------------------------
# Token compartilhado entre Vercel Cron e /api/cron/*.
# Gere uma string aleatória forte: openssl rand -hex 32
CRON_SECRET=CHANGE_ME

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
